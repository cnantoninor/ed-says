{
  "name": "ed-says",
  "version": "0.1.0",
  "description": "Ed Says your team's knowledge debt is showing — GitHub PR Epistemic Debt Analyzer",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ed-says": "dist/bin.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ test/",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "package": "ncc build src/index.ts -o dist-action --source-map --license licenses.txt",
    "prepare": "npm run build"
  },
  "keywords": [
    "epistemic-debt",
    "code-quality",
    "github-action",
    "pull-request",
    "complexity",
    "knowledge-management"
  ],
  "author": "arau6",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cnantoninor/ed-says.git"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "ai": "^4.0.0",
    "zod": "^3.24.0",
    "yaml": "^2.6.0",
    "commander": "^13.0.0",
    "chalk": "^5.4.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.3.0",
    "@vercel/ncc": "^0.38.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
